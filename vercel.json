{
  "rewrites": [
    {
      "source": "/api/innoreation/v1/proxy/chat/completions",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/stepfun/(.*)",
      "destination": "https://api.stepfun.com/$1"
    },
    {
      "source": "/api/modelscope/(.*)",
      "destination": "https://api-inference.modelscope.cn/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}